# Profilul public Google Scholar al Irinei Vilciu
GOOGLE_SCHOLAR_PROFILE_URL=https://scholar.google.com/citations?user=sSYoPq0AAAAJ

# Metoda de acces la Google Scholar:
# auto = folosește SerpApi dacă există cheia; altfel încearcă scholarly
# valori acceptate: auto, serpapi, scholarly
SCHOLAR_BACKEND=auto

# Cheia SerpApi se completează numai în fișierul local .env
# Nu introduceți cheia reală în acest fișier public
SERPAPI_API_KEY=

# 0 înseamnă fără limită
MAX_PUBLICATIONS=0
MAX_CITATIONS_PER_PUBLICATION=0

# Fișierul Excel care va fi generat
OUTPUT_FILE=data/output/Raport_OMEC_3018_Comisia_9_Irina_Vilciu.xlsx
